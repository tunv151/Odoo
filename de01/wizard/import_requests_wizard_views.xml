<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Wizard Form View -->
    <record id="view_import_requests_wizard_form" model="ir.ui.view">
        <field name="name">import.requests.wizard.form</field>
        <field name="model">import.requests.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="lead_id" invisible="1"/>
                    <field name="filename" invisible="1"/>
                    <field name="file" string="File Excel" filename="filename"/>
                </group>
                <footer>
                    <button string="Nhập dữ liệu" name="action_import" type="object" class="btn-primary"/>
                    <button string="Hủy" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Wizard Action -->
    <record id="action_import_requests_wizard" model="ir.actions.act_window">
        <field name="name">Nhập Nhu cầu từ Excel</field>
        <field name="res_model">import.requests.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_crm_lead"/>
        <field name="binding_view_types">form</field>
    </record>
</odoo>